{
    "manifest_version": 3,
    "name": "Ext.to PikPak Assistant",
    "version": "1.0",
    "description": "Find Torrents, Get Magnets, and Check PikPak ​​in Just One Step",
    "permissions": [
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "https://ext.to/*",
        "https://api-drive.mypikpak.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://ext.to/browse/*"
            ],
            "js": [
                "search-page.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
         "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png",
            "256": "icons/icon256.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png",
        "256": "icons/icon256.png"
    }
}